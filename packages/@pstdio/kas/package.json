{
  "name": "@pstdio/kas",
  "type": "module",
  "description": "A simple coding agent for the browser.",
  "version": "0.3.0",
  "author": "Pufflig AB",
  "email": "support@prompt.studio",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pufflyai/kaset.git"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./kas-ui": {
      "import": "./dist/kas-ui.js",
      "types": "./dist/kas-ui.d.ts"
    },
    "./opfs-tools": {
      "import": "./dist/opfs-tools.js",
      "types": "./dist/opfs-tools.d.ts"
    },
    "./plugin-tools": {
      "import": "./dist/plugin-tools.js",
      "types": "./dist/plugin-tools.d.ts"
    }
  },
  "scripts": {
    "prepublishOnly": "bun run build",
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "bun run typecheck && vitest run --passWithNoTests",
    "lint": "biome lint src",
    "typecheck": "tsc --noEmit",
    "visualize-bundle": "bunx vite-bundle-visualizer"
  },
  "devDependencies": {
    "@au-re/vite-plugin-externalize-deps": "^0.9.1",
    "@types/node": "^22.15.18",
    "typescript": "^5.7.3",
    "vite": "^7.1.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@pstdio/opfs-utils": "^0.2.1",
    "@pstdio/prompt-utils": "^0.1.4",
    "@pstdio/tiny-ai-tasks": "^0.3.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ]
}
