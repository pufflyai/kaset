{
  "name": "@pstdio/tiny-ui-bundler",
  "description": "Wrapper around esbuild-wasm including a service worker for in-browser caching of js code.",
  "version": "0.1.3",
  "author": "Pufflig AB",
  "email": "support@prompt.studio",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pufflyai/kaset.git"
  },
  "scripts": {
    "start": "storybook dev -p 6006",
    "storybook": "storybook dev -p 6006",
    "prepublishOnly": "bun run build",
    "build": "tsc -b && vite build",
    "lint": "biome lint src",
    "visualize-bundle": "bunx vite-bundle-visualizer",
    "test": "vitest run --passWithNoTests"
  },
  "keywords": [],
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sw": {
      "types": "./dist/sw.d.ts",
      "import": "./dist/sw.js"
    },
    "./opfs": {
      "types": "./dist/opfs/index.d.ts",
      "import": "./dist/opfs.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@au-re/vite-plugin-externalize-deps": "^0.9.1",
    "@types/node": "^22.18.0",
    "typescript": "^5.7.3",
    "vite": "^7.1.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@pstdio/opfs-utils": "^0.2.1",
    "esbuild-wasm": "^0.25.10"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  }
}
